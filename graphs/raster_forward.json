{
  "name": "raster_forward",
  "passes": [
    {
      "name": "SceneUpload",
      "type": "SceneUploadPass"
    },
    {
      "name": "HardwareRasterForward",
      "type": "HardwareRasterPass",
      "shader": "raster_forward.slang",
      "output": "color",
      "color": [0.1, 0.45, 0.9, 1.0]
    },
    {
      "name": "ToneMap",
      "type": "ToneMapPass",
      "output": "color"
    },
    {
      "name": "Present",
      "type": "PresentPass"
    }
  ],
  "edges": [
    {"from": "SceneUpload.scene", "to": "HardwareRasterForward.scene"},
    {"from": "HardwareRasterForward.color", "to": "ToneMap.input"},
    {"from": "ToneMap.color", "to": "Present.input"}
  ],
  "outputs": ["Present.presented"],
  "settings": {
    "description": "Hardware raster smoke graph."
  }
}
